{
  "name": "marginalia",
  "version": "0.1.0",
  "description": "Obsidian plugin that injects friction into your writing by surfacing past notes that contradict or structurally mirror what you're writing.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "typecheck": "tsc -noEmit -skipLibCheck"
  },
  "keywords": ["obsidian", "plugin", "ollama", "rag"],
  "author": "gen",
  "license": "MIT",
  "type": "module",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "0.21.5",
    "obsidian": "latest",
    "tslib": "2.6.2",
    "typescript": "5.4.5"
  }
}
